# Per-environment cron config. Copy to data/musicbrainz/<env>.env (gitignored)
# for each environment you run cron jobs against: dev, staging, production.
#
#   cp scripts/env.example data/musicbrainz/dev.env   # then fill in
#
# data/ is gitignored, so real connection strings and the ntfy topic never land
# in git. The ntfy topic is effectively a secret (anyone who knows it can
# publish/subscribe) — keep it here only.

# Neon connection string for THIS environment's corpus (use the matching branch).
DATABASE_URL='postgresql://USER:PASS@HOST/neondb?sslmode=require'

# Cap on backlog candidates -> caps the corpus size.
#   dev / staging: 1000  (tiny sample, resolves in one pass)
#   production:    leave UNSET / commented out for the full ~6M catalog
CANDIDATE_LIMIT=1000

# Recordings resolved per resolve run.
#   dev / staging: 1000  (one pass covers the whole capped backlog)
#   production:    ~16000 (hourly, grows the full corpus incrementally)
RESOLVE_LIMIT=1000

# healthchecks.io ping URL for this job (dead-man's-switch). Create one check per
# job per env; if a ping is overdue (incl. because the Mac is off) it alerts.
# Route its notifications to ntfy in the healthchecks.io integrations UI.
# HEALTHCHECK_URL='https://hc-ping.com/your-uuid-here'

# ntfy topic for INSTANT phone push on job failure (secret — pick something
# unguessable). Subscribe to it in the ntfy app on your phone.
# NTFY_TOPIC='randomify-ALONGRANDOMSTRING'
